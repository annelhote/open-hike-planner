{
  "name": "open-hike-planner",
  "homepage": "https://annelhote.github.io/open-hike-planner/",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "concurrently": "^8.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "author": "annelhote",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm -w client run build",
    "client": "npm -w client run start",
    "server": "npm -w server fastapi run main.py"
  }
}